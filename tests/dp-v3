# Production docker-compose
# Nginx runs on the host (not containerized) — manages SSL via Let's Encrypt
# Services expose ports to localhost for nginx to proxy to
# Auth: enterprise Keycloak + RTX SSO (no local Keycloak container)

services:
  clarity-api:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: clarity-api
    environment:
      - CLARITY_SQL_DB=${CLARITY_SQL_DB}
      - CLARITY_SQL_USER=${CLARITY_SQL_USER}
      - CLARITY_SQL_PASSWORD=${CLARITY_SQL_PASSWORD}
      - CLARITY_SQL_HOST=clarity-db
      - CLARITY_SQL_PORT=5432
      - CLARITY_KC_HOST=${CLARITY_KC_HOST}
      - CLARITY_KC_PORT=${CLARITY_KC_PORT}
      - CLARITY_KC_REALM=${CLARITY_KC_REALM}
      - CLARITY_KC_ADMIN=${CLARITY_KC_ADMIN}
      - CLARITY_KC_ADMIN_PASSWORD=${CLARITY_KC_ADMIN_PASSWORD}
      - CORP_OIDC_CLIENT_ID=${CORP_OIDC_CLIENT_ID}
      - CORP_OIDC_CLIENT_SECRET=${CORP_OIDC_CLIENT_SECRET}
      - CORP_OIDC_DISCOVERY_ENDPOINT=${CORP_OIDC_DISCOVERY_ENDPOINT}
      - CORP_OIDC_ISSUER=${CORP_OIDC_ISSUER}
      - CORP_OIDC_AUTHORIZATION_URL=${CORP_OIDC_AUTHORIZATION_URL}
      - CORP_OIDC_TOKEN_URL=${CORP_OIDC_TOKEN_URL}
      - CORP_OIDC_JWKS_URL=${CORP_OIDC_JWKS_URL}
      - CORP_OIDC_USER_INFO_URL=${CORP_OIDC_USER_INFO_URL}
      - META_OPENAI_URL_BASE=${META_OPENAI_URL_BASE}
      - META_OPENAI_URL=${META_OPENAI_URL}
      - META_OPENAI_KEY=${META_OPENAI_KEY}
      - ARCHER_USERNAME=${ARCHER_USERNAME}
      - ARCHER_PASSWORD=${ARCHER_PASSWORD}
      - ARCHER_INSTANCE_NAME=${ARCHER_INSTANCE_NAME}
      - ARCHER_BASE_URL=${ARCHER_BASE_URL}
      - ARCHER_SOAP_SEARCH_URI=${ARCHER_SOAP_SEARCH_URI}
      - ARCHER_SOAP_GENERAL_URI=${ARCHER_SOAP_GENERAL_URI}
      - MAPPING_EXPORT=${MAPPING_EXPORT}
      - SEED_DATA=${SEED_DATA}
      - AUTH_MODE=${AUTH_MODE:-keycloak-enterprise}
      - ENTERPRISE_KC_SERVER_URL=${ENTERPRISE_KC_SERVER_URL}
      - ENTERPRISE_KC_REALM=${ENTERPRISE_KC_REALM}
      - ENTERPRISE_KC_CLIENT_ID=${ENTERPRISE_KC_CLIENT_ID}
      - ENTERPRISE_KC_CLIENT_SECRET=${ENTERPRISE_KC_CLIENT_SECRET}
    ports:
      - "127.0.0.1:4000:4000"
    depends_on:
      db:
        condition: service_healthy
    networks:
      - clarity_network
    restart: unless-stopped

  clarity-frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      args:
        NUXT_PUBLIC_API_BASE_URL: /be
        NUXT_PUBLIC_AUTH_MODE: ${AUTH_MODE:-keycloak-enterprise}
    container_name: clarity-frontend
    environment:
      - NUXT_PUBLIC_API_BASE_URL=/be
      - NUXT_PUBLIC_AUTH_MODE=${AUTH_MODE:-keycloak-enterprise}
      - NUXT_OIDC_ISSUER=${CORP_OIDC_ISSUER}
      - NUXT_OIDC_CLIENT_ID=${CORP_OIDC_CLIENT_ID}
      - NUXT_OIDC_CLIENT_SECRET=${CORP_OIDC_CLIENT_SECRET}
      - NUXT_OIDC_AUTHORIZATION_URL=${CORP_OIDC_AUTHORIZATION_URL}
      - NUXT_OIDC_TOKEN_URL=${CORP_OIDC_TOKEN_URL}
      - NUXT_OIDC_JWKS_URL=${CORP_OIDC_JWKS_URL}
      - NUXT_OIDC_USER_INFO_URL=${CORP_OIDC_USER_INFO_URL}
      - NUXT_OIDC_REDIRECT_URI=https://clarity.onertx.com/auth/sso/callback
      - ENTERPRISE_KC_SERVER_URL=${ENTERPRISE_KC_SERVER_URL}
      - ENTERPRISE_KC_REALM=${ENTERPRISE_KC_REALM}
      - ENTERPRISE_KC_CLIENT_ID=${ENTERPRISE_KC_CLIENT_ID}
      - ENTERPRISE_KC_CLIENT_SECRET=${ENTERPRISE_KC_CLIENT_SECRET}
    ports:
      - "127.0.0.1:3000:3000"
    depends_on:
      - clarity-api
    networks:
      - clarity_network
    restart: unless-stopped

  db:
    image: postgres:17
    container_name: clarity-db
    environment:
      POSTGRES_DB: ${CLARITY_SQL_DB}
      POSTGRES_USER: ${CLARITY_SQL_USER}
      POSTGRES_PASSWORD: ${CLARITY_SQL_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - clarity_network
    ports:
      - "127.0.0.1:5432:5432"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${CLARITY_SQL_USER} -d ${CLARITY_SQL_DB}"]
      interval: 5s
      timeout: 5s
      retries: 10

networks:
  clarity_network:
    driver: bridge

volumes:
  postgres_data:




CMD ["python", "-c", "import ssl; ssl._create_default_https_context = ssl._create_unverified_context; import uvicorn; uvicorn.run('src.clarity.api:api', host='0.0.0.0', port=4000)"]
