### Dockerfile ###

FROM node:20-alpine AS base
WORKDIR /app

# Install dependencies
FROM base AS deps
COPY package.json package-lock.json* yarn.lock* pnpm-lock.yaml* ./
RUN \
  if [ -f yarn.lock ]; then yarn install --frozen-lockfile; \
  elif [ -f pnpm-lock.yaml ]; then corepack enable pnpm && pnpm install --frozen-lockfile; \
  elif [ -f package-lock.json ]; then npm ci; \
  else npm install; \
  fi

# Build the Nuxt app
FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build args become env vars at build time
ARG NUXT_PUBLIC_API_BASE_URL=/api
ARG NUXT_PUBLIC_AUTH_MODE=keycloak-enterprise
ENV NUXT_PUBLIC_API_BASE_URL=${NUXT_PUBLIC_API_BASE_URL}
ENV NUXT_PUBLIC_AUTH_MODE=${NUXT_PUBLIC_AUTH_MODE}

RUN npm run build

# Production runner
FROM base AS runner
ENV NODE_ENV=production

# Copy the Nuxt output
COPY --from=builder /app/.output ./.output

EXPOSE 3000

### nginx.conf ###

# /nginx/nginx.conf

upstream frontend {
    server clarity-frontend:3000;
}

upstream backend {
    server clarity-api:4000;
}

upstream keycloak {
    server clarity-keycloak:8080;
}

server {
    listen 80;
    server_name clarity.onertx.com;

    # Health check for ALB / monitoring
    location /nginx-health {
        access_log off;
        return 200 'ok';
        add_header Content-Type text/plain;
    }

    # Keycloak (must come before the catch-all)
    location /kc/ {
        proxy_pass http://keycloak/kc/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;
    }

    # Backend API
    location /api/ {
        proxy_pass http://backend/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend health check (direct passthrough)
    location /api/health {
        proxy_pass http://backend/health;
    }

    # SSO callback and auth routes — must go to frontend
    location /auth/ {
        proxy_pass http://frontend/auth/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend (catch-all)
    location / {
        proxy_pass http://frontend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

